# Database (Supabase)
# Go to Supabase > Project Settings > Database > Connection string > URI
# Use the "Transaction" pooler URL (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=https://your-app.vercel.app

# AI Provider (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# PubMed / NCBI E-utilities API (for citation verification)
# Get a key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your-ncbi-api-key

# Pangram Labs (optional, SOTA AI detector — free dev key ~25-50 calls/day)
# Sign up at: https://pangram.com/ -> Dashboard -> API Keys
PANGRAM_API_KEY=your-pangram-api-key

# Sapling (optional, modern AI detector — free tier ~50k chars/month)
# Get a key at: https://sapling.ai/ -> Dashboard -> API Keys
SAPLING_API_KEY=your-sapling-api-key

# Google OAuth (for SSO)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Site Password Protection (set to enable, remove to disable)
SITE_PASSWORD=your-site-password

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_UNLIMITED_PRICE_ID=price_...

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
